{
  "name": "@jzszdznzzl/wabotjs",
  "description": "A lightweight WhatsApp bot framework built on baileys and TypeScript.",
  "version": "2.0.1",
  "private": false,
  "author": {
    "name": "jzszdznzzl",
    "url": "https://github.com/jzszdznzzl"
  },
  "license": "MIT",
  "keywords": [
    "whatsapp",
    "baileys",
    "wabot",
    "wabotjs",
    "node",
    "typescript"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jzszdznzzl/wabotjs.git"
  },
  "bugs": {
    "url": "https://github.com/jzszdznzzl/wabotjs/issues"
  },
  "homepage": "https://github.com/jzszdznzzl/wabotjs#readme",
  "files": [
    "dist/",
    "docs/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.test.ts",
    "build": "npm run build:docs && tsc",
