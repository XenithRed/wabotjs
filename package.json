    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "dependencies": {
    "@hapi/boom": "10.0.1",
    "baileys": "7.0.0-rc13",
    "libphonenumber-js": "1.13.7",
    "link-preview-js": "4.0.4",
    "long": "5.3.2",
