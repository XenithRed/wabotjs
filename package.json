    "pino": "10.3.1"
  },
  "devDependencies": {
    "@types/ms": "2.1.0",
    "@types/node": "24",
    "@types/qrcode": "1.5.6",
    "qrcode": "1.5.4",
    "tsx": "4.22.4",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.12.0",
    "typescript": "6.0.3"
  }
